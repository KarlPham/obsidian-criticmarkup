{
    "name": "obsidian-criticmarkup",
    "version": "0.2.6",
    "type": "module",
    "description": "A CriticMarkup plugin for Obsidian",
    "main": "main.js",
    "scripts": {
        "dev": "bun run esbuild.config.mjs; obsidian plugin:reload id=commentator",
        "build": "bun run tsc -noEmit -skipLibCheck && bun scripts/build/esbuild.config.ts production",
        "build:dev": "bun run tsc -noEmit -skipLibCheck && bun scripts/build/esbuild.config.ts development",
        "lint": "bun eslint src/",
        "format": "bun dprint fmt",
        "test": "jest --verbose",
        "release-patch": "bun run scripts/release/bump-version.ts --type patch",
        "release-minor": "bun run scripts/release/bump-version.ts --type minor",
        "release-major": "bun run scripts/release/bump-version.ts --type major",
        "release-rc": "bun run scripts/release/bump-version.ts --rc",
        "postinstall": "npx bun run scripts/postinstall.ts"
    },
    "keywords": [],
    "author": "kometenstaub and Fevol",
    "license": "MIT",
    "devDependencies": {
        "@types/jest": "^29.5.14",
        "@typescript-eslint/eslint-plugin": "^8.58.1",
        "@typescript-eslint/parser": "^8.58.1",
        "commander": "^13.1.0",
        "dprint": "^0.49.1",
        "eslint": "^8.57.1",
        "eslint-plugin-deprecation": "^3.0.0",
        "eslint-plugin-svelte": "^3.17.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "jest-expect-message": "^1.1.3",
        "jsdom": "^26.1.0",
        "obsidian-typings": "^4.111.0",
        "patch-package": "^8.0.1",
        "prettier": "3.5.3",
        "svelte-eslint-parser": "^1.6.0",
        "ts-jest": "^29.4.9",
        "tslib": "^2.8.1"
    },
    "dependencies": {
        "@codemirror/buildhelper": "^1.0.2",
        "@codemirror/language": "github:fevol-forks/cm-language",
        "@flatten-js/interval-tree": "^1.1.4",
        "@lezer/generator": "^1.8.0",
        "@lezer/lr": "^1.4.8",
        "@tsconfig/svelte": "^5.0.8",
        "@types/bun": "^1.3.12",
        "@types/diff-match-patch": "^1.0.36",
        "@types/node": "^22.19.17",
        "builtin-modules": "^5.1.0",
        "diff-match-patch": "^1.0.5",
        "esbuild": "^0.25.12",
        "esbuild-jest": "^0.5.0",
        "esbuild-sass-plugin": "^3.7.0",
        "esbuild-svelte": "^0.9.4",
        "localforage": "^1.10.0",
        "localforage-getitems": "github:conversejs/localForage-getItems",
        "localforage-setitems": "^1.4.0",
        "monkey-around": "^3.0.0",
        "obsidian": "^1.12.3",
        "svelte": "^5.55.3",
        "svelte-preprocess": "^6.0.3",
        "svelty-picker": "^6.1.6",
        "typescript": "^5.9.3"
    },
    "trustedDependencies": [
        "@codemirror/language"
    ],
    "overrides": {
        "@lezer/common": "^1.2.3"
    }
}
